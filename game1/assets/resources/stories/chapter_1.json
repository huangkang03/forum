  "chapters": [
    {
      "id": "ch1_1",
      "title": "转学第一天",
      "background": "backgrounds/school_gate",
      "bgm": "bgm/school_theme",
      "dialogues": [
        {
          "id": "d1",
          "speaker": null,
          "speakerName": "",
          "text": "春天，新学期开始的第一天。我转学到了这所陌生的学校。",
          "effects": [{ "type": "fadeIn", "duration": 0.8 }]
        },
        {
          "id": "d2",
          "speaker": "protagonist",
          "speakerName": "我",
          "text": "这里就是新学校吗……比想象的要大啊。"
        },
        {
          "id": "d3",
          "speaker": null,
          "speakerName": "",
          "text": "校门口的樱花树正值盛放，花瓣随风飘落，像是在迎接新学期的到来。",
          "effects": [{ "type": "zoomIn", "duration": 2.0 }]
        },
        {
          "id": "d4",
          "speaker": "heroine",
          "speakerName": "小樱",
          "text": "你好！你也是新生吗？",
          "emotion": "happy"
        },
        {
          "id": "d5",
          "speaker": "protagonist",
          "speakerName": "我",
          "text": "呃……是的。我是转校生。"
        },
        {
          "id": "d6",
          "speaker": null,
          "speakerName": "",
          "text": "面前的女孩有着一头樱粉色的长发，眼睛清澈明亮。她微笑着，让人莫名地感到安心。",
          "effects": [{ "type": "zoomIn", "duration": 1.5 }]
        },
        {
          "id": "d7",
          "speaker": "heroine",
          "speakerName": "小樱",
          "text": "太好了！我也是刚转来没多久。我叫小樱，请多关照！",
          "emotion": "happy",
          "choices": [
            {
              "text": "礼貌地回应",
              "jumpTo": "d8_polite",
              "actions": [
                { "type": "affection", "key": "heroine", "value": 1 }
              ]
            },
            {
              "text": "不知所措，沉默以对",
              "jumpTo": "d8_silent",
              "actions": []
            }
          ]
        },
        {
          "id": "d8_polite",
          "speaker": "protagonist",
          "speakerName": "我",
          "text": "你好，小樱。我叫林晓。很高兴认识你。",
          "jumpTo": "d9"
        },
        {
          "id": "d8_silent",
          "speaker": "protagonist",
          "speakerName": "我",
          "text": "……（不知该说什么，只是点了点头）",
          "jumpTo": "d9"
        },
        {
          "id": "d9",
          "speaker": "heroine",
          "speakerName": "小樱",
          "text": "那我先带你逛逛校园吧！这所学校虽然不大，但是有很多有趣的地方哦。",
          "emotion": "happy",
          "actions": [
            { "type": "setFlag", "key": "meet_sakura" },
            { "type": "setFlag", "key": "school_tour" }
          ]
        },
        {
          "id": "d10",
          "speaker": null,
          "speakerName": "",
          "text": "就这样，我的新校园生活，在樱花纷飞的季节里开始了。",
          "effects": [{ "type": "fadeOut", "duration": 1.0 }]
        }
      ]
    }
  ]
}
